# === PostgreSQL ===
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_local_pw

# === Redis ===
REDIS_PASSWORD=redis_local_pw

# === Kafka ===
KAFKA_BROKER_ID=1

# === Schema Registry ===
SCHEMA_REGISTRY_PORT=8086

# === OpenSearch ===
DISCOVERY_TYPE=single-node

# === App Services — Spring profiles ===
SPRING_PROFILES_ACTIVE=local

# === App Services — DB ===
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/synapse
SPRING_DATASOURCE_USERNAME=synapse
SPRING_DATASOURCE_PASSWORD=synapse_local_pw

# === App Services — Redis ===
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=redis_local_pw

# === App Services — Kafka ===
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SPRING_KAFKA_PROPERTIES_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# === App Services — OpenSearch ===
OPENSEARCH_URL=http://opensearch:9200
